#!/usr/bin/env python3
"""
lobster-jobs: Transform and manage Lobster workflows for OpenClaw cron jobs.

Tier 1 commands: list, inspect, validate
"""

import argparse
import json
import os
import re
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from typing import Any, Optional, Tuple


# Constants
PAYLOAD_SYSTEM_EVENT = "systemEvent"
PAYLOAD_AGENT_TURN = "agentTurn"
MIN_JOB_ID_PREFIX_LENGTH = 4
SUBPROCESS_TIMEOUT_SECONDS = 30
USE_EMOJI = True

EMOJI = {
    "status_full": "✅",
    "status_partial": "🟡",
    "status_none": "❌",
    "lobster": "🦞",
    "enabled": "🟢",
    "disabled": "⚪",
    "summary": "📊",
    "tip": "💡",
    "inspect": "🔍",
    "details": "📋",
    "recommend": "💡",
    "warn": "⚠️",
    "next": "📋",
    "ok": "✅",
    "error": "❌",
}

# Generate text fallbacks from emoji keys to avoid duplication
EMOJI_TEXT = {k: f"[{k.upper().replace('_', ' ')}]" for k in EMOJI}


def emoji(key: str) -> str:
    """Return emoji or plain-text alternative based on global flag."""
    table = EMOJI if USE_EMOJI else EMOJI_TEXT
    if key not in table:
        raise KeyError(f"Unknown emoji key: {key}")
    return table[key]


class MigrationStatus(Enum):
    """Lobster migration readiness categories."""
    FULLY_MIGRATABLE = "fully_migratable"
    PARTIAL = "partial"
    NOT_MIGRATABLE = "not_migratable"

    def emoji(self) -> str:
        return {
            MigrationStatus.FULLY_MIGRATABLE: emoji("status_full"),
            MigrationStatus.PARTIAL: emoji("status_partial"),
            MigrationStatus.NOT_MIGRATABLE: emoji("status_none"),
        }[self]

    def label(self) -> str:
        return {
            MigrationStatus.FULLY_MIGRATABLE: "Fully Migratable",
            MigrationStatus.PARTIAL: "Partial Migration",
            MigrationStatus.NOT_MIGRATABLE: "Not Migratable",
        }[self]


@dataclass
class CronJob:
    """Represents an OpenClaw cron job."""
    id: str
    name: str
    enabled: bool
    schedule: dict[str, Any]
    payload: dict[str, Any]
    status: MigrationStatus
    reason: str

    @property
    def kind(self) -> str:
        value = self.payload.get("kind", "unknown")
        return value if isinstance(value, str) else "unknown"

    @property
    def schedule_str(self) -> str:
        """Return human-readable schedule."""
        sched = self.schedule
        if sched.get("kind") == "cron":
            expr = sched.get("expr", "")
            tz = sched.get("tz", "UTC")
            return f"{expr} ({tz})"
        elif sched.get("kind") == "every":
            ms = sched.get("everyMs", 0)
            minutes = ms // 60000
            return f"every {minutes} min"
        return "unknown"


def categorize_job(job: dict) -> Tuple[MigrationStatus, str]:
    """Categorize a cron job by Lobster migratability."""
    payload = job.get("payload", {})
    kind = payload.get("kind", "unknown")
    
    if kind == PAYLOAD_SYSTEM_EVENT:
        text = payload.get("text", "")
        # Check if it's a simple shell command
        if re.match(r'^(exec|bash|sh|python|python3|node|npm|pnpm)\s', text.strip()):
            return MigrationStatus.FULLY_MIGRATABLE, "Simple shell command - fully deterministic"
        return MigrationStatus.PARTIAL, "systemEvent but complex command structure"
    
    if kind == PAYLOAD_AGENT_TURN:
        message = payload.get("message", "")
        
        # Check for clear exec steps
        exec_patterns = [
            r'Run:\s*\`?([^\`\n]+)',
            r'Execute:\s*\`?([^\`\n]+)',
            r'(?:^|\n)(?:\d+\.\s*)?(?:bash|python|python3|node|npm|pnpm)\s+',
        ]
        
        has_exec_steps = any(re.search(pattern, message) for pattern in exec_patterns)
        
        # Check for heavy LLM reasoning indicators
        reasoning_indicators = [
            r'(summarize|analyze|decide|classify|triage|draft|generate|create)\s',
            r'(check|review|assess|evaluate)\s+(if|whether)',
            r'ask\s+(user|Martin)',
            r'reply\s+(here|with)',
        ]
        
        has_reasoning = any(re.search(pattern, message, re.IGNORECASE) for pattern in reasoning_indicators)
        
        if has_exec_steps and not has_reasoning:
            return MigrationStatus.PARTIAL, "Has exec steps but may need LLM judgment"
        elif has_exec_steps and has_reasoning:
            return MigrationStatus.PARTIAL, "Mixed: exec steps + LLM reasoning - isolate LLM steps"
        else:
            return MigrationStatus.NOT_MIGRATABLE, "Heavy LLM reasoning required"
    
    return MigrationStatus.NOT_MIGRATABLE, f"Unknown payload kind: {kind}"


def fetch_cron_jobs() -> list[CronJob]:
    """Fetch cron jobs through the legacy Moltbot CLI alias."""
    try:
        result = subprocess.run(
            ["moltbot", "cron", "list", "--json"],
            capture_output=True,
            text=True,
            check=True,
            timeout=SUBPROCESS_TIMEOUT_SECONDS,
            shell=False,
        )
        
        # Parse JSON (handle plugin output before JSON)
        output = result.stdout
        try:
            data = json.loads(output)
        except json.JSONDecodeError:
            # Use raw_decode to find JSON start more reliably
            decoder = json.JSONDecoder()
            # Search for either object '{' or array '[' start
            for start_char in ['{', '[']:
                pos = output.find(start_char)
                while pos != -1:
                    try:
                        data, _ = decoder.raw_decode(output, pos)
                        break
                    except json.JSONDecodeError:
                        # Try next occurrence of start char
                        pos = output.find(start_char, pos + 1)
                else:
                    continue
                break
            else:
                raise json.JSONDecodeError("No valid JSON object or array found", output, 0)
        jobs = data.get("jobs", [])
        
        cron_jobs = []
        for job in jobs:
            status, reason = categorize_job(job)
            cron_jobs.append(CronJob(
                id=job.get("id", "unknown"),
                name=job.get("name", "Unnamed"),
                enabled=job.get("enabled", False),
                schedule=job.get("schedule", {}),
                payload=job.get("payload", {}),
                status=status,
                reason=reason,
            ))
        
        return cron_jobs
    
    except subprocess.TimeoutExpired:
        print(f"{emoji('error')} Timeout fetching cron jobs after {SUBPROCESS_TIMEOUT_SECONDS}s", file=sys.stderr)
        sys.exit(1)
    except subprocess.CalledProcessError as e:
        print(f"{emoji('error')} Error fetching cron jobs: {e}", file=sys.stderr)
        print(f"stderr: {e.stderr}", file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"{emoji('error')} Error parsing JSON: {e}", file=sys.stderr)
        sys.exit(1)


def cmd_list(args: argparse.Namespace) -> int:
    """List all cron jobs with their Lobster readiness."""
    jobs = fetch_cron_jobs()
    
    if not jobs:
        print("No cron jobs found.")
        return 0
    
    # Group by status
    by_status: dict[MigrationStatus, list[CronJob]] = {
        MigrationStatus.FULLY_MIGRATABLE: [],
        MigrationStatus.PARTIAL: [],
        MigrationStatus.NOT_MIGRATABLE: [],
    }
    
    for job in jobs:
        by_status[job.status].append(job)
    
    # Print summary
    total = len(jobs)
    print(f"\n{emoji('lobster')} Lobster Migration Report")
    print(f"   {total} cron job{'s' if total != 1 else ''} found\n")
    
    # Print by category
    for status in [MigrationStatus.FULLY_MIGRATABLE, MigrationStatus.PARTIAL, MigrationStatus.NOT_MIGRATABLE]:
        jobs_in_cat = by_status[status]
        if jobs_in_cat:
            print(f"{status.emoji()} {status.label()} ({len(jobs_in_cat)})")
            print("-" * 60)
            for job in jobs_in_cat:
                enabled = emoji("enabled") if job.enabled else emoji("disabled")
                print(f"  {enabled} {job.name}")
                print(f"     ID: {job.id[:8]}... | Schedule: {job.schedule_str}")
                print(f"     └─ {job.reason}")
            print()
    
    # Summary stats
    full = len(by_status[MigrationStatus.FULLY_MIGRATABLE])
    partial = len(by_status[MigrationStatus.PARTIAL])
    not_mig = len(by_status[MigrationStatus.NOT_MIGRATABLE])
    
    print(f"{emoji('summary')} Summary: {full} fully migratable, {partial} partial, {not_mig} not migratable")
    print(f"\n{emoji('tip')} Tip: Run 'lobster-jobs inspect <job-id>' for detailed analysis\n")
    
    return 0


def find_job_by_id(jobs: list[CronJob], job_id: str) -> Optional[CronJob]:
    """Find a job by ID or prefix. Warns if multiple jobs match."""
    # Exact match first
    exact_match = next((j for j in jobs if j.id == job_id), None)
    if exact_match:
        return exact_match
    
    # Prefix match
    if len(job_id) < MIN_JOB_ID_PREFIX_LENGTH:
        print(f"{emoji('warn')}  Job ID prefix '{job_id}' is too short (min {MIN_JOB_ID_PREFIX_LENGTH} chars)", file=sys.stderr)
        return None
    
    prefix_matches = [j for j in jobs if j.id.startswith(job_id)]
    if len(prefix_matches) > 1:
        print(f"{emoji('error')} Multiple jobs match prefix '{job_id}':", file=sys.stderr)
        for j in prefix_matches[:5]:
            print(f"   - {j.name} ({j.id[:16]}...)", file=sys.stderr)
        return None
    elif len(prefix_matches) == 1:
        return prefix_matches[0]
    
    return None


def cmd_inspect(args: argparse.Namespace) -> int:
    """Inspect a specific cron job."""
    job_id = args.job_id
    jobs = fetch_cron_jobs()
    
    job = find_job_by_id(jobs, job_id)
    
    if not job:
        print(f"{emoji('error')} Job not found: {job_id}", file=sys.stderr)
        print(f"   Run 'lobster-jobs list' to see available jobs", file=sys.stderr)
        return 1
    
    print(f"\n{emoji('inspect')} Job Inspection: {job.name}")
    print("=" * 60)
    print(f"  ID:        {job.id}")
    print(f"  Status:    {emoji('enabled')} Enabled" if job.enabled else f"  Status:    {emoji('disabled')} Disabled")
    print(f"  Schedule:  {job.schedule_str}")
    print(f"  Target:    {job.payload.get('sessionTarget', 'unknown')}")
    print(f"  Payload:   {job.kind}")
    print()
    
    print(f"{emoji('lobster')} Lobster Migration Assessment")
    print("-" * 60)
    print(f"  Status:   {job.status.emoji()} {job.status.label()}")
    print(f"  Reason:   {job.reason}")
    print()
    
    # Show payload details
    print(f"{emoji('details')} Payload Details")
    print("-" * 60)
    if job.kind == "systemEvent":
        text = job.payload.get("text", "")
        print(f"  Command: {text[:100]}{'...' if len(text) > 100 else ''}")
    elif job.kind == "agentTurn":
        message = job.payload.get("message", "")
        model = job.payload.get("model", "default")
        print(f"  Model: {model}")
        print(f"  Message preview:")
        lines = message.split('\n')[:5]
        for line in lines:
            print(f"    {line[:70]}{'...' if len(line) > 70 else ''}")
        if len(message.split('\n')) > 5:
            print(f"    ... ({len(message.split('\n')) - 5} more lines)")
    
    print()
    
    # Migration recommendation
    print(f"{emoji('recommend')} Recommendation")
    print("-" * 60)
    if job.status == MigrationStatus.FULLY_MIGRATABLE:
        print(f"  {emoji('ok')} Ready to migrate with 'lobster-jobs convert'")
        print("  └─ This job can be fully converted to a deterministic Lobster workflow")
    elif job.status == MigrationStatus.PARTIAL:
        print(f"  {emoji('status_partial')} Can be partially migrated")
        print("  └─ Extract deterministic steps to Lobster, keep LLM steps in wrapper")
        print("  └─ Consider using 'llm.invoke' for LLM judgment within workflow")
    else:
        print(f"  {emoji('status_none')} Not recommended for migration")
        print("  └─ Keep as agentTurn - heavy LLM reasoning required")
    
    print()
    return 0


def cmd_new(args: argparse.Namespace) -> int:
    """Create a new Lobster workflow from scratch."""
    workflow_name = args.name.lower().replace(" ", "-").replace("_", "-")
    
    # Determine output path
    workflow_dir = Path(args.output_dir or "~/.lobster/workflows").expanduser()
    workflow_dir.mkdir(parents=True, exist_ok=True)
    
    workflow_path = workflow_dir / f"{workflow_name}.lobster"
    
    # Check if file already exists
    if workflow_path.exists() and not args.force:
        print(f"{emoji('error')} Workflow already exists: {workflow_path}", file=sys.stderr)
        print(f"   Use --force to overwrite", file=sys.stderr)
        return 1
    
    # Load template
    template_name = args.template
    template_path = Path(__file__).parent.parent / "templates" / f"{template_name}.lobster"
    
    if not template_path.exists():
        # Create inline templates
        templates = {
            "simple-shell": """name: {name}
description: A simple shell command workflow

steps:
  - id: execute
    command: echo "Replace with your command"
    capture: output
    
  - id: result
    command: echo "Result: $execute.output"
""",
            "with-approval": """name: {name}
description: Workflow with approval gate

steps:
  - id: prepare
    command: echo "Preparing..."
    capture: output
    
  - id: confirm
    command: approve --prompt "Proceed with action?"
    approval: required
    
  - id: execute
    command: echo "Executing..."
    condition: $confirm.approved
""",
            "stateful": """name: {name}
description: Stateful workflow with cursor tracking

steps:
  - id: load_state
    command: cat ~/.lobster/state/{name}.json 2>/dev/null || echo '{}'
    capture: state
    
  - id: process
    command: echo "Processing..."
    capture: output
    
  - id: save_state
    command: echo '{{"cursor": "'$process.output'"}}' > ~/.lobster/state/{name}.json
"""
        }
        
        workflow_content = templates.get(template_name, templates["simple-shell"]).format(name=workflow_name)
    else:
        with open(template_path, 'r') as f:
            template_content = f.read()
        # Replace placeholders
        workflow_content = template_content.replace("name: example-", f"name: {workflow_name}")
        workflow_content = workflow_content.replace("example workflow", f"{workflow_name} workflow")
    
    # Write workflow file
    try:
        with open(workflow_path, 'w') as f:
            f.write(workflow_content)
        print(f"{emoji('ok')} Created workflow: {workflow_path}")
    except IOError as e:
        print(f"{emoji('error')} Error writing workflow: {e}", file=sys.stderr)
        return 1
    
    # Validate the generated workflow
    print(f"\n{emoji('inspect')} Validating generated workflow...")
    args.workflow_file = str(workflow_path)
    validate_result = cmd_validate(args)
    
    if validate_result != 0:
        print(f"{emoji('warn')}  Generated workflow has validation issues", file=sys.stderr)
        return 1
    
    print(f"\n{emoji('tip')} Next steps:")
    print(f"   Edit: {workflow_path}")
    print(f"   Test: lobster run {workflow_path}")
    print()
    
    return 0


def cmd_validate(args: argparse.Namespace) -> int:
    """Validate a Lobster workflow file."""
    workflow_arg = args.workflow_file
    
    # Resolve path and verify it's within allowed bounds
    workflow_path = Path(workflow_arg).expanduser()
    
    if workflow_path.is_absolute():
        # For absolute paths, use parent directory as base
        base_dir = workflow_path.parent.resolve()
        resolved_path = workflow_path.resolve()
    else:
        # For relative paths, resolve against cwd
        base_dir = Path.cwd().resolve()
        resolved_path = (base_dir / workflow_path).resolve()
    
    # Verify resolved path is within base directory (prevents path traversal)
    try:
        resolved_path.relative_to(base_dir)
    except ValueError:
        print(f"{emoji('error')} Path traversal is not allowed: {workflow_arg}", file=sys.stderr)
        return 1
    
    workflow_path = resolved_path
    
    if not workflow_path.exists():
        print(f"{emoji('error')} File not found: {workflow_path}", file=sys.stderr)
        return 1
    
    try:
        import yaml
    except ImportError:
        print(f"{emoji('error')} Missing dependency: PyYAML is required for validation", file=sys.stderr)
        print("   Install with: pip install pyyaml", file=sys.stderr)
        return 2  # Exit code 2 for missing dependency
    
    try:
        with open(workflow_path, 'r') as f:
            content = f.read()
    except IOError as e:
        print(f"{emoji('error')} Error reading file: {e}", file=sys.stderr)
        return 1
    
    print(f"\n{emoji('inspect')} Validating: {workflow_path}")
    print("-" * 60)
    
    # Parse YAML
    try:
        workflow = yaml.safe_load(content)
    except yaml.YAMLError as e:
        print(f"{emoji('error')} YAML parse error: {e}", file=sys.stderr)
        return 1
    
    errors = []
    warnings = []
    
    # Check required fields
    if not workflow.get("name"):
        errors.append("Missing required field: 'name'")
    
    steps = workflow.get("steps", [])
    if not steps:
        errors.append("No steps defined in workflow")
    
    # Validate steps
    for i, step in enumerate(steps):
        step_id = step.get("id", f"step_{i}")
        
        if not step.get("id"):
            errors.append(f"Step {i}: Missing 'id'")
        
        if not step.get("command"):
            errors.append(f"Step {step_id}: Missing 'command'")
        
        # Check for reserved words
        if step.get("approval") and step.get("approval") not in ["required", "optional"]:
            warnings.append(f"Step {step_id}: Unknown approval value '{step['approval']}'")
        
        # Validate condition syntax (basic check)
        condition = step.get("condition")
        if condition and not isinstance(condition, (str, bool)):
            warnings.append(f"Step {step_id}: Condition should be string or boolean")
    
    # Report results
    if errors:
        print(f"{emoji('error')} Validation failed ({len(errors)} errors):")
        for err in errors:
            print(f"   • {err}")
    
    if warnings:
        print(f"{emoji('warn')}  Warnings ({len(warnings)}):")
        for warn in warnings:
            print(f"   • {warn}")
    
    if not errors and not warnings:
        print(f"{emoji('ok')} Valid Lobster workflow")
        print(f"   Name: {workflow.get('name')}")
        print(f"   Steps: {len(steps)}")
        print(f"   Description: {workflow.get('description', 'N/A')[:60]}")
    
    print()
    return 1 if errors else 0


def sanitize_workflow_name(name: str) -> str:
    """Sanitize job name for use as workflow name."""
    # Replace unsafe characters
    sanitized = name.lower()
    for char in [" ", "_", "(", ")", "/", "\\", "<", ">", ":", '"', "|", "?", "*"]:
        sanitized = sanitized.replace(char, "-")
    # Remove consecutive dashes
    while "--" in sanitized:
        sanitized = sanitized.replace("--", "-")
    # Remove leading/trailing dashes
    sanitized = sanitized.strip("-")
    return sanitized or "workflow"


def generate_workflow(job: CronJob) -> str:
    """Generate a Lobster workflow YAML from a cron job."""
    payload = job.payload
    kind = payload.get("kind", "unknown")
    
    workflow_name = sanitize_workflow_name(job.name)
    
    steps = []
    
    if kind == PAYLOAD_SYSTEM_EVENT:
        text = payload.get("text", "").strip()
        # Extract the actual command
        cmd = text
        if cmd.startswith("exec "):
            cmd = cmd[5:]
        
        # Validate command doesn't contain dangerous characters
        if any(c in cmd for c in ['\n', '\r', '\x00']):
            cmd = cmd.split('\n')[0].strip()
        
        steps.append({
            "id": "execute",
            "command": cmd,
            "capture": "output"
        })
        
        # Add notification step if it looks like it produces output
        if any(word in cmd.lower() for word in ["alert", "notify", "send", "report"]):
            steps.append({
                "id": "notify",
                "command": "echo \"$execute.output\"",
                "condition": "len($execute.output) > 0",
                "approval": "optional"
            })
    
    elif kind == PAYLOAD_AGENT_TURN:
        message = payload.get("message", "")
        
        # Try to extract exec commands from the message
        exec_patterns = [
            r'(?:Run|Execute):?\s*[`\']?([^`\'\n]+)',
            r'(?:^|\n)(?:\d+\.\s*)?(?:bash|python|python3|node|npm|pnpm)\s+([^\n]+)',
        ]
        
        extracted_commands = []
        for pattern in exec_patterns:
            matches = re.findall(pattern, message, re.MULTILINE | re.IGNORECASE)
            extracted_commands.extend(matches)
        
        if extracted_commands:
            for i, cmd in enumerate(extracted_commands):
                cmd = cmd.strip()
                # Sanitize extracted command
                if any(c in cmd for c in ['\n', '\r', '\x00']):
                    cmd = cmd.split('\n')[0].strip()
                if cmd:
                    steps.append({
                        "id": f"step_{i+1}",
                        "command": cmd,
                        "capture": "output"
                    })
        
        # If no commands extracted, add a placeholder
        if not steps:
            steps.append({
                "id": "placeholder",
                "command": "echo 'Replace with actual command'",
                "comment": "Extract commands from original agentTurn message"
            })
    
    # Add warning for agentTurn workflows with extracted commands
    warning_comment = ""
    if kind == PAYLOAD_AGENT_TURN and extracted_commands:
        warning_comment = f"""# WARNING: This workflow was auto-generated from an agentTurn job.
# Commands were extracted using regex patterns and may require manual review.
# Original job: {job.name}
# Please verify all extracted commands before running in production.

"""
    
    workflow = {
        "name": workflow_name,
        "description": f"Migrated from cron job: {job.name}",
        "steps": steps
    }
    
    # Convert to YAML using safe dump
    try:
        import yaml
        # Use safe_dump to prevent arbitrary object serialization
        yaml_output = yaml.safe_dump(workflow, default_flow_style=False, sort_keys=False, allow_unicode=True)
        return warning_comment + yaml_output
    except ImportError:
        # Fallback to manual YAML generation with proper escaping
        yaml_lines = [f"name: {workflow_name}", f"description: Migrated from cron job: {job.name}", "steps:"]
        for step in steps:
            yaml_lines.append(f"  - id: {step['id']}")
            # Properly escape the command for YAML
            cmd = step['command']
            if '"' in cmd or ':' in cmd or cmd.startswith(' ') or cmd.endswith(' '):
                # Use single quotes if no single quotes in command
                if "'" not in cmd:
                    yaml_lines.append(f"    command: '{cmd}'")
                else:
                    # Use double quotes and escape
                    cmd_escaped = cmd.replace('\\', '\\\\').replace('"', '\\"')
                    yaml_lines.append(f'    command: "{cmd_escaped}"')
            else:
                yaml_lines.append(f"    command: {cmd}")
            if "capture" in step:
                yaml_lines.append(f"    capture: {step['capture']}")
            if "condition" in step:
                yaml_lines.append(f"    condition: {step['condition']}")
            if "approval" in step:
                yaml_lines.append(f"    approval: {step['approval']}")
        return "\n".join(yaml_lines)


def cmd_convert(args: argparse.Namespace) -> int:
    """Convert a cron job to a Lobster workflow."""
    job_id = args.job_id
    jobs = fetch_cron_jobs()
    
    job = find_job_by_id(jobs, job_id)
    
    if not job:
        print(f"{emoji('error')} Job not found: {job_id}", file=sys.stderr)
        print(f"   Run 'lobster-jobs list' to see available jobs", file=sys.stderr)
        return 1
    
    # Check if migration is recommended
    if job.status == MigrationStatus.NOT_MIGRATABLE and not args.force:
        print(f"{emoji('error')} Job is marked as NOT_MIGRATABLE: {job.name}", file=sys.stderr)
        print(f"   Reason: {job.reason}", file=sys.stderr)
        print(f"   Use --force to override", file=sys.stderr)
        return 1
    
    # Determine output path
    workflow_dir = Path(args.output_dir or "~/.lobster/workflows").expanduser()
    workflow_dir.mkdir(parents=True, exist_ok=True)
    
    workflow_name = sanitize_workflow_name(job.name)
    workflow_path = workflow_dir / f"{workflow_name}.lobster"
    
    # Check if file already exists
    if workflow_path.exists() and not args.force:
        print(f"{emoji('error')} Workflow already exists: {workflow_path}", file=sys.stderr)
        print(f"   Use --force to overwrite", file=sys.stderr)
        return 1
    
    # Generate workflow
    workflow_yaml = generate_workflow(job)
    
    # Write workflow file atomically using temp file + rename
    temp_path = None
    fd = None
    try:
        # Create temp file in same directory for atomic move
        fd, temp_path = tempfile.mkstemp(
            dir=workflow_dir,
            prefix=f".{workflow_name}.tmp-",
            suffix=".lobster"
        )
        try:
            # Write using os.write to avoid fdopen issues, then close explicitly
            os.write(fd, workflow_yaml.encode('utf-8'))
            os.close(fd)
            fd = None  # Mark as closed
            # Atomic rename
            os.replace(temp_path, workflow_path)
            print(f"{emoji('ok')} Created workflow: {workflow_path}")
        except Exception:
            # Clean up temp file on error
            if fd is not None:
                try:
                    os.close(fd)
                except Exception:
                    pass
            if temp_path and os.path.exists(temp_path):
                try:
                    os.unlink(temp_path)
                except Exception:
                    pass
            raise
    except IOError as e:
        print(f"{emoji('error')} Error writing workflow: {e}", file=sys.stderr)
        return 1
    
    # Validate the generated workflow
    print(f"\n{emoji('inspect')} Validating generated workflow...")
    args.workflow_file = str(workflow_path)
    validate_result = cmd_validate(args)
    
    if validate_result != 0:
        print(f"{emoji('warn')}  Generated workflow has validation issues", file=sys.stderr)
        if not args.keep_on_error:
            workflow_path.unlink()
            print(f"   Deleted: {workflow_path}", file=sys.stderr)
        return 1
    
    # Print next steps
    print(f"\n{emoji('next')} Next Steps")
    print("-" * 60)
    print(f"1. Review the workflow: cat {workflow_path}")
    print(f"2. Test manually: lobster run {workflow_path}")
    
    if args.update_cron:
        print(f"3. Update cron job to use Lobster (not yet implemented)")
    else:
        print(f"3. To update the cron job, run with --update-cron")
    
    print()
    return 0


def main() -> int:
    """Main entry point."""
    parser = argparse.ArgumentParser(
        prog="lobster-jobs",
        description="Transform and manage Lobster workflows for OpenClaw cron jobs",
    )
    parser.add_argument("--no-emoji", action="store_true", help="Disable emoji in output")
    
    subparsers = parser.add_subparsers(dest="command", help="Available commands")
    
    # list command
    list_parser = subparsers.add_parser("list", help="List all cron jobs with Lobster readiness")
    list_parser.set_defaults(func=cmd_list)
    
    # inspect command
    inspect_parser = subparsers.add_parser("inspect", help="Inspect a specific cron job")
    inspect_parser.add_argument("job_id", help="Job ID (or prefix)")
    inspect_parser.set_defaults(func=cmd_inspect)
    
    # validate command
    validate_parser = subparsers.add_parser("validate", help="Validate a Lobster workflow file")
    validate_parser.add_argument("workflow_file", help="Path to .lobster workflow file")
    validate_parser.set_defaults(func=cmd_validate)
    
    # convert command
    convert_parser = subparsers.add_parser("convert", help="Convert a cron job to Lobster workflow")
    convert_parser.add_argument("job_id", help="Job ID (or prefix)")
    convert_parser.add_argument("--output-dir", "-o", help="Output directory for workflow (default: ~/.lobster/workflows)")
    convert_parser.add_argument("--force", "-f", action="store_true", help="Overwrite existing workflow")
    convert_parser.add_argument("--keep-on-error", action="store_true", help="Keep workflow file even if validation fails")
    convert_parser.add_argument("--update-cron", action="store_true", help="Update cron job to call Lobster (not yet implemented)")
    convert_parser.set_defaults(func=cmd_convert)
    
    # new command
    new_parser = subparsers.add_parser("new", help="Create a new Lobster workflow from scratch")
    new_parser.add_argument("name", help="Workflow name (kebab-case recommended)")
    new_parser.add_argument("--output-dir", "-o", help="Output directory (default: ~/.lobster/workflows)")
    new_parser.add_argument("--template", "-t", choices=["simple-shell", "with-approval", "stateful"],
                          default="simple-shell", help="Template to use")
    new_parser.add_argument("--force", "-f", action="store_true", help="Overwrite existing workflow")
    new_parser.set_defaults(func=cmd_new)
    
    args = parser.parse_args()
    global USE_EMOJI
    USE_EMOJI = not args.no_emoji
    
    if not args.command:
        parser.print_help()
        return 1
    
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
